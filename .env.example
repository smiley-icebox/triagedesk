# Copy to .env and fill in. The classifier needs an Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---------------------------------------------------------------
# Set to 0 to use template-only responses (no LLM-generated replies; lets the app
# run with no API key).
# USE_LLM_RESPONSES=1

# Storage engine. Unset => SQLite. A postgres:// URL selects a Postgres backend
# (see repository.build_repository — the swap point).
# DATABASE_URL=postgresql://user:pass@localhost:5432/triagedesk

# Opt-in LangSmith tracing — exports every LLM call. No code change needed.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=triagedesk
